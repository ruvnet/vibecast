{
  "name": "agentic-graph",
  "version": "0.1.0",
  "description": "Ultra-fast LangGraph-compatible agentic workflow engine powered by Rust/WASM - 2500x faster than Python",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-graph": "./dist/cli.js",
    "agentdb": "./dist/agentdb-cli.js",
    "agentic-optimize": "./dist/optimize-cli.js"
  },
  "scripts": {
    "build": "npm run build:ts",
    "build:wasm": "cd crates/langgraph-wasm && wasm-pack build --target nodejs --out-dir ../../pkg",
    "build:napi": "cd crates/langgraph-napi && cargo build --release && napi build --platform --release",
    "build:full": "npm run build:wasm && npm run build:napi && npm run build:ts",
    "build:ts": "tsc && chmod +x dist/cli.js dist/agentdb-cli.js dist/optimize-cli.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "benchmark": "node dist/benchmark-runner.js",
    "benchmark:compare": "node dist/benchmark-compare.js",
    "swe-bench": "node dist/swe-bench.js",
    "swe-bench:advanced": "node dist/swe-bench-advanced.js",
    "swe-bench:industry": "node dist/swe-bench-industry.js",
    "swe-bench:real": "node dist/swe-bench-real.js",
    "swe-bench:final": "node dist/swe-bench-final.js",
    "swe-bench:optimized": "node dist/swe-bench-optimized.js",
    "test-model": "node dist/model-tester.js",
    "optimize": "node dist/optimize-cli.js optimize",
    "optimize:orchestrator": "node dist/optimized-orchestrator.js",
    "optimize:models": "node dist/optimize-cli.js models",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build && npm test",
    "postinstall": "npm run build:napi || echo 'Native addon build failed, falling back to TypeScript/WASM'",
    "mcp:stdio": "node dist/mcp-server.js stdio",
    "mcp:sse": "node dist/mcp-server.js sse"
  },
  "keywords": [
    "langgraph",
    "workflow",
    "agent",
    "agentic",
    "graph",
    "rust",
    "wasm",
    "performance",
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "state-machine"
  ],
  "author": "LangGraph Rust Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/vibecast.git"
  },
  "bugs": {
    "url": "https://github.com/ruvnet/vibecast/issues"
  },
  "homepage": "https://github.com/ruvnet/vibecast#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist",
    "pkg",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "ora": "^5.4.1",
    "table": "^6.8.1",
    "cli-table3": "^0.6.3",
    "express": "^4.18.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.9",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2",
    "prettier": "^3.1.0"
  },
  "optionalDependencies": {
    "@napi-rs/cli": "^2.18.0"
  },
  "napi": {
    "name": "langgraph-napi",
    "triples": {
      "defaults": true,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "aarch64-apple-darwin",
        "x86_64-pc-windows-msvc"
      ]
    }
  }
}
