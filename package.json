{
  "name": "vibecast",
  "version": "1.0.0",
  "description": "VibeCast - AI-powered entertainment discovery to solve the 45-minute decision problem",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pro": "node dist/demo-pro.js",
    "start:maker": "node dist/demo-maker.js",
    "dev": "ts-node src/index.ts",
    "dev:pro": "ts-node src/demo-pro.ts",
    "dev:maker": "ts-node src/demo-maker.ts",
    "benchmark": "ts-node src/demo-maker.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prepare": "npm run build"
  },
  "keywords": [
    "entertainment",
    "discovery",
    "ai",
    "agentic",
    "vibecast",
    "streaming",
    "recommendation",
    "multi-agent",
    "vector-embeddings",
    "hackathon"
  ],
  "author": "VibeCast Team",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "ruvector": "^0.1.24",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
