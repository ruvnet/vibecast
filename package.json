{
  "name": "@vibecast/franchise-manager",
  "version": "1.0.0",
  "description": "Multi-agent franchise management platform for business analysis, planning, and growth optimization",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./api": {
      "require": "./dist/api/index.js",
      "import": "./dist/api/index.mjs",
      "types": "./dist/api/index.d.ts"
    },
    "./cli": {
      "require": "./dist/cli/index.js",
      "import": "./dist/cli/index.mjs",
      "types": "./dist/cli/index.d.ts"
    }
  },
  "bin": {
    "franchise": "dist/cli/index.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:cjs && npm run build:esm",
    "build:types": "tsc --emitDeclarationOnly",
    "build:cjs": "tsc --module commonjs --outDir dist",
    "build:esm": "tsc --module esnext --outDir dist --outExtension .js=.mjs",
    "build:wasm": "node scripts/build-wasm.js",
    "clean": "node scripts/clean.js",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "deploy": "node scripts/deploy.js",
    "prepublishOnly": "npm run test && npm run build",
    "prepare": "npm run build",
    "example:basic": "node examples/basic-franchise.js",
    "example:analysis": "node examples/multi-agent-analysis.js",
    "example:growth": "node examples/growth-planning.js"
  },
  "keywords": [
    "franchise",
    "management",
    "multi-agent",
    "business-analysis",
    "growth-planning",
    "ai-agents",
    "franchise-operations",
    "business-intelligence"
  ],
  "author": "rUv <ruv@vibecast.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vibecast/franchise-manager.git"
  },
  "bugs": {
    "url": "https://github.com/vibecast/franchise-manager/issues"
  },
  "homepage": "https://github.com/vibecast/franchise-manager#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "better-sqlite3": "^9.2.2",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "inquirer": "^8.2.5",
    "node-fetch": "^3.3.2",
    "openai": "^6.8.1",
    "ora": "^5.4.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.24",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "canvas": "^2.11.2"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  }
}
