{
  "name": "cloudflare-mcp-server",
  "version": "0.1.0",
  "description": "Model Context Protocol (MCP) implementation using Cloudflare Workers",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run dev:minimal",
    "dev:wrangler": "wrangler dev",
    "dev:mock": "node scripts/mock-server.js",
    "dev:express": "node scripts/express-server.js",
    "dev:standalone": "node scripts/standalone-express-server.js",
    "dev:simple": "node scripts/simple-express-server.js",
    "dev:minimal": "node scripts/minimal-server.js",
    "start": "npm run dev:minimal",
    "deploy": "wrangler publish",
    "format": "prettier --write '**/*.{js,ts}'",
    "lint": "eslint --ext .js,.ts .",
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit",
    "test:integration": "jest --testPathPattern=integration",
    "test:e2e": "jest --testPathPattern=e2e",
    "validate:dev": "node scripts/validate.js dev",
    "validate:production": "node scripts/validate.js production",
    "validate:local": "node scripts/validate.js local",
    "load-test": "node scripts/load-test.js production",
    "load-test:local": "node scripts/load-test.js local",
    "security-check": "node scripts/security-check.js production",
    "security-check:local": "node scripts/security-check.js local"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "mcp",
    "model-context-protocol"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20230518.0",
    "@types/jest": "^29.5.1",
    "@types/node": "^20.1.0",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5",
    "chalk": "^5.4.1",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "^8.8.0",
    "express": "^5.1.0",
    "jest": "^29.5.0",
    "miniflare": "^4.20250428.1",
    "node-fetch": "^3.3.2",
    "prettier": "^2.8.8",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.4",
    "wrangler": "^3.105.0"
  },
  "dependencies": {
    "itty-router": "^3.0.12",
    "zod": "^3.21.4"
  }
}
