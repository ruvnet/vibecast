      "description": "Relay station failure and recovery simulation",
      "parameters": {
        "duration_hours": 24,
        "messages_per_hour": 75,
        "relay_failure_schedule": {
          "hour_6": "l4_earth_offline",
          "hour_12": "l5_earth_offline",
          "hour_18": "l4_earth_recovered"
