      "description": "Adaptive protocol behavior under varying conditions",
      "parameters": {
        "duration_hours": 36,
        "messages_per_hour": 100,
        "varying_conditions": {
          "latency_profiles": ["interactive", "delayed_interactive", "store_and_forward"],
          "bandwidth_variations": [0.5, 1.0, 2.0, 0.8, 1.5],
          "error_rates": [0.001, 0.01, 0.05, 0.001]
