{
  "simulation_scenarios": {
    "earth_mars_communication": {
      "description": "Standard Earth-Mars communication with varying orbital distances",
      "parameters": {
        "duration_hours": 24,
        "messages_per_hour": 50,
        "orbital_positions": {
          "earth_angle": 0,
          "mars_angle": 0.785398
        },
        "traffic_types": {
          "emergency": 5,
          "critical": 15,
          "normal": 60,
          "bulk_data": 20
        }
      },
      "expected_metrics": {
        "min_delay_minutes": 4,
        "max_delay_minutes": 24,
        "success_rate_percent": 95,
        "relay_usage_percent": 15
      }
    },
    "solar_conjunction_test": {
      "description": "Communication during solar conjunction when sun blocks direct path",
      "parameters": {
        "duration_hours": 48,
        "messages_per_hour": 30,
        "orbital_positions": {
          "earth_angle": 0,
          "mars_angle": 3.14159
        },
        "solar_interference": true,
        "relay_mandatory": true
      },
      "expected_metrics": {
        "min_delay_minutes": 8,
        "max_delay_minutes": 48,
        "success_rate_percent": 85,
        "relay_usage_percent": 100
      }
    },
