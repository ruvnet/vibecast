{
  "name": "@ruvio/agent-graph",
  "version": "0.1.0",
  "description": "High-performance LangGraph implementation in Rust/WASM with 100% Python API compatibility",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:wasm && npm run build:js",
    "build:wasm": "wasm-pack build --target bundler --out-dir ../npm/wasm ../crates/langgraph-wasm",
    "build:js": "rollup -c",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "langgraph",
    "wasm",
    "graph",
    "workflow",
    "agent",
    "ai",
    "rust",
    "typescript"
  ],
  "author": "ruv.io",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ruvnet/vibecast"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "rollup": "^4.9.4",
    "typescript": "^5.3.3",
    "wasm-pack": "^0.12.1"
  },
  "dependencies": {}
}
