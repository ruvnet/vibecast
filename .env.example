# Vibecast Agentic Platform Configuration

# Database (Supabase / PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Environment
NODE_ENV=development

# Router 2.0 Configuration
ROUTER_DAILY_BUDGET_CAP=10.00
ROUTER_BUDGET_ALERT_THRESHOLD=0.80

# Policy Engine
POLICY_ENFORCEMENT=strict
POLICY_LOG_VIOLATIONS=true

# Privacy & Security
PII_REDACTION_MODE=replace
AUTO_REDACT_ON_EGRESS=true
AUDIT_LOG_SIGNING_KEY=your-signing-key-here

# Telemetry & Observability
TELEMETRY_ENABLED=true
TELEMETRY_SERVICE_NAME=vibecast-agentic-platform
TELEMETRY_ENVIRONMENT=development

# Flow-Nexus Sandbox (Optional)
FLOW_NEXUS_ENABLED=false
FLOW_NEXUS_ENDPOINT=http://localhost:8080

# Exception Handling
EXCEPTION_SLA_MINUTES=240
EXCEPTION_AUTO_ESCALATE=true

# Feature Flags
ENABLE_RULE_SYNTHESIS=true
ENABLE_AUTO_DEPLOYMENT=false
ENABLE_EXECUTIVE_DASHBOARDS=true
