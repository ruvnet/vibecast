# PubNub Configuration
# Sign up for free at: https://www.pubnub.com/

# For development, you can use the demo keys:
PUBNUB_PUBLISH_KEY=demo
PUBNUB_SUBSCRIBE_KEY=demo

# For production, use your own keys:
# PUBNUB_PUBLISH_KEY=your-publish-key-here
# PUBNUB_SUBSCRIBE_KEY=your-subscribe-key-here

# Optional: Custom user ID (defaults to auto-generated UUID)
# PUBNUB_USER_ID=my-custom-user-id

# Optional: Enable verbose logging
# PUBNUB_LOG_VERBOSITY=true
