# Anthropic API Configuration
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AgentDB Configuration (Supabase)
AGENTDB_URL=your_supabase_url_here
AGENTDB_KEY=your_supabase_anon_key_here
AGENTDB_SERVICE_KEY=your_supabase_service_key_here

# Agentic-Flow Configuration
AGENTIC_FLOW_POLICY=./config/agentic-flow.policy.yaml
OPENROUTER_API_KEY=your_openrouter_key_here

# Flow-Nexus Configuration
FLOW_NEXUS_ENDPOINT=http://localhost:3000
FLOW_NEXUS_API_KEY=your_flow_nexus_key_here

# Application Configuration
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Privacy and Security
ENABLE_ENCRYPTION=true
ENCRYPTION_KEY=your_32_byte_encryption_key_here
ENABLE_LEAN_PROOFS=true
