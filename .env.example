# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/flowmanager
# For SQLite: sqlite://./data/flowmanager.db

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=iipflowmanagerprod
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=document-intake
AZURE_STORAGE_QUARANTINE_CONTAINER=document-intake-quarantine

# OpenTelemetry
OTEL_SERVICE_NAME=flowmanager-document-intake
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_SAMPLING_RATIO=1.0
OTEL_LOG_LEVEL=info

# Application Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
MAX_FILE_SIZE_BYTES=104857600
IDEMPOTENCY_TTL_HOURS=24
UPLOAD_TIMEOUT_MS=300000

# Security
JWT_SECRET=your-jwt-secret-here
ALLOWED_ORIGINS=http://localhost:3000
