# Alpaca API Credentials
# Get your API keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_secret_key_here

# E2B API Key
# Get your API key from: https://e2b.dev/docs
E2B_API_KEY=your_e2b_api_key_here

# Trading Configuration
TRADING_MODE=paper  # paper or live
DEFAULT_STRATEGY=momentum  # momentum, mean-reversion, sentiment
RISK_TOLERANCE=0.02  # 2% risk per trade
